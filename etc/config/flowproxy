config infra 'infra'
	option common_port '22,53,80,143,443,465,853,873,993,995,5222,8080,8443,9418'
	option mixed_port '5330'
	option redirect_port '5331'
	option tproxy_port '5332'
	option dns_port '5333'
	option ntp_server 'time.apple.com'
	option sniff_override '1'
	option tun_name 'singtun0'
	option tun_addr4 '172.19.0.1/30'
	option tun_addr6 'fdfe:dcba:9876::1/126'
	option tun_mtu '9000'
	option clash_api_port '9090'
	option clash_api_host '0.0.0.0'

config config 'config'
	option routing_mode 'custom'
	option proxy_mode 'redirect_tproxy'
	option ipv6_support '1'
	option log_level 'warn'
	option tg_notify_enabled '0'
	option location_name 'FlowProxy-Router'
	option tg_notify_mode 'fail_only'

config control 'control'
	option lan_proxy_mode 'disabled'
	list wan_proxy_ipv4_ips '91.105.192.0/23'
	list wan_proxy_ipv4_ips '91.108.4.0/22'
	list wan_proxy_ipv4_ips '91.108.8.0/22'
	list wan_proxy_ipv4_ips '91.108.16.0/22'
	list wan_proxy_ipv4_ips '91.108.12.0/22'
	list wan_proxy_ipv4_ips '91.108.20.0/22'
	list wan_proxy_ipv4_ips '91.108.56.0/22'
	list wan_proxy_ipv4_ips '149.154.160.0/20'
	list wan_proxy_ipv4_ips '185.76.151.0/24'
	list wan_proxy_ipv4_ips '203.208.50.66/32'

config routing 'routing'
	option sniff_override '1'
	option default_outbound 'nil'
	option default_outbound_dns 'alidns'
	option bypass_cn_traffic '0'
	option domain_strategy 'prefer_ipv4'

config dns 'dns'
	option dns_strategy 'prefer_ipv4'
	option default_server 'googledns'
	option default_strategy 'prefer_ipv4'

config subscription 'subscription'
	option auto_update '0'
	option allow_insecure '0'
	option packet_encoding 'xudp'
	option update_via_proxy '0'
	option filter_nodes 'blacklist'
	option user_agent 'flowproxy-core'
	list filter_keywords '重置|到期|过期|剩余|套餐'
	list filter_keywords 'Expiration|Remaining'
	list filter_keywords '网址'
	list global_regions 'US'

config server 'server'
	option enabled '0'
	option log_level 'warn'

config dns_server 'alidns'
	option label 'Ali-DNS'
	option enabled '1'
	option type 'https'
	option server '223.5.5.5'
	option outbound 'direct-out'

config dns_server 'googledns'
	option label 'Google-DNS'
	option enabled '1'
	option type 'https'
	option server '8.8.8.8'
	option outbound 'us01'

config dns_server 'cloudflaredns'
	option label 'Cloudflare-DNS'
	option enabled '1'
	option type 'https'
	option server '1.1.1.1'
	option outbound 'us01'

config dns_rule 'LocalDNS'
	option label 'Local'
	option enabled '1'
	option mode 'default'
	option action 'route'
	option server 'alidns'
	option domain_strategy 'prefer_ipv4'
	list rule_set 'geositecn'

config dns_rule 'Remot'
	option label 'Proxy'
	option enabled '1'
	option mode 'default'
	option action 'route'
	option server 'cloudflaredns'
	list rule_set 'geositenoncn'
	option domain_strategy 'prefer_ipv4'

config routing_rule 'categoryadsall'
	option label 'Category-Ads'
	option enabled '1'
	option mode 'default'
	list rule_set 'geositecategoryadsall'
	option action 'reject'
	option reject_method 'default'

config routing_rule 'china'
	option label 'China'
	option enabled '1'
	option mode 'default'
	option action 'route'
	option outbound 'direct-out'
	list rule_set 'geoipcn'
	list rule_set 'geositecn'
	list process_path_regex '0'

config ruleset 'geositecn'
	option label 'geosite-cn'
	option enabled '1'
	option type 'local'
	option format 'binary'
	option path '/etc/flowproxy/ruleset/geosite-cn.srs'

config ruleset 'geositenoncn'
	option label 'geosite-geolocation-!cn'
	option enabled '1'
	option type 'local'
	option format 'binary'
	option path '/etc/flowproxy/ruleset/geosite-geolocation-!cn.srs'

config ruleset 'geositecategoryadsall'
	option label 'geosite-category-ads-all'
	option enabled '1'
	option type 'local'
	option format 'binary'
	option path '/etc/flowproxy/ruleset/geosite-category-ads-all.srs'

config ruleset 'geoipcn'
	option label 'geoip-cn'
	option enabled '1'
	option type 'local'
	option format 'binary'
	option path '/etc/flowproxy/ruleset/geoip-cn.srs'

config zashboard 'panel'
	option theme 'dark'
	option lang 'zh-CN'

config routing_rule 'proxy'
	option label 'proxy'
	option enabled '1'
	option mode 'default'
	list rule_set 'geositenoncn'
	option action 'route'
	option outbound 'us01'
	list process_path_regex '0'

config assets 'assets'
	option base_url 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing'
	option private_repo 'https://raw.githubusercontent.com/Vonzhen/sing-box-rulesets/refs/heads/master/rules'
	option auto_update '1'
	option update_time '7'

