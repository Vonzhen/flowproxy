config flowproxy 'routing'
	option sniff_override '1'
	option default_outbound 'us04'
	option default_outbound_dns 'alidns'
	option bypass_cn_traffic '0'
	option domain_strategy 'prefer_ipv4'

config flowproxy 'dns'
	option dns_strategy 'prefer_ipv4'
	option default_server 'googledns'
	option default_strategy 'prefer_ipv4'

config flowproxy 'subscription'
	option auto_update '0'
	option allow_insecure '0'
	option packet_encoding 'xudp'
	option update_via_proxy '0'
	option filter_nodes 'blacklist'
	option user_agent 'flowproxy'
	list global_regions 'HK'
	list global_regions 'SG'
	list global_regions 'US'
	list global_regions 'JP'
	list filter_keywords '重置|到期|过期|剩余|套餐'
	list filter_keywords 'Expiration|Remaining'
	list filter_keywords '网址'

config flowproxy 'server'
	option enabled '0'
	option log_level 'warn'

config assets 'assets'
	option base_url 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing'
	option private_repo 'https://raw.githubusercontent.com/Vonzhen/sing-box-rulesets/refs/heads/master/rules'
